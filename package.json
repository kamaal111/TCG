    "@hono/node-server": "^2.0.11",
    "@hono/swagger-ui": "~0.6.1",
    "@hono/zod-openapi": "^1.5.1",
    "@kamaalio/kamaal": "~0.8.0",
    "better-auth": "1.7.0-rc.1",
    "drizzle-orm": "1.0.0-rc.4",
    "hono": "^4.12.31",
    "jose": "^6.2.4",
    "js-yaml": "^5.2.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "auth": "1.7.0-rc.1",
    "drizzle-kit": "1.0.0-rc.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "oxlint-tsgolint": "^7.0.2001",
